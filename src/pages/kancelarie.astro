---
import BaseLayout from '../layouts/BaseLayout.astro';
import RealizacieGrid from '../components/RealizacieGrid.astro';
import { getCollection } from 'astro:content';
const title = 'Kancelárie — Auresa Design Studio';
const description = 'Interiérový dizajn pre kancelárie a komerčné priestory. Priestor ako tichý náborový nástroj.';
const realizacie = (await getCollection('realizacie'))
  .map((e) => ({ ...e.data, slug: e.slug }))
  .filter((d) => d.vertikala === 'kancelarie')
  .sort((a, b) => b.rok - a.rok);
---
<BaseLayout title={title} description={description}>
  <section class="au-page-hero">
    <div class="d1-eyebrow"><span class="d1-eyebrow-title">Kancelárie</span></div>
    <h1>Priestor ako <em>tichý náborový nástroj.</em></h1>
  </section>
  <div class="au-prose">
    <p>Kancelária už nie je len adresa, kam sa ráno presúvate. Je to to, čo zamestnanca pritiahne, ale aj to, čo udrží jeho sústredenie v prvých minútach týždňa.</p>
  </div>

  <section class="d1-section">
    <div class="d1-eyebrow"><span class="d1-eyebrow-title">Realizácie</span></div>
    <RealizacieGrid items={realizacie} />
    <div class="au-stub-cta" style="margin-top:48px">
      <a href="/#kontakt" class="au-cta">Napíšte nám <span class="arr">→</span></a>
      <a href="/realizacie/" class="au-cta">Všetky realizácie <span class="arr">→</span></a>
    </div>
  </section>
</BaseLayout>
