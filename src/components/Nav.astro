---
/* Navigácia — sticky, transparent → bone pri scrolle. Všetkých 5 položiek sú
   plnohodnotné odkazy (jeden {label, href} vzor): 3 vertikály na podstránky,
   O mne / Kontakt kotvy. Logo = preklik na úvod. Mobile: hamburger. */
import logo from '../assets/logo/auresa_logo_ink_tight.svg?raw';
import { VERTS } from '../data/site';

// Jednotný zoznam položiek menu — rovnaký <a> pre všetky (žiadny text-only/button).
const navLinks = [
  ...VERTS.map((v) => ({ label: v.title, href: `/${v.slug}/` })),
  { label: 'O mne', href: '/#o-mne' },
  { label: 'Kontakt', href: '/#kontakt' },
];
---
<header class="au-nav" id="au-nav">
  <a href="/" class="au-nav__logo" aria-label="Auresa Design Studio — domov" set:html={logo}></a>

  <button class="au-nav__toggle" aria-label="Menu" aria-expanded="false" aria-controls="au-nav-links">
    <span></span>
  </button>

  <nav class="au-nav__links" id="au-nav-links" aria-label="Hlavná navigácia">
    {navLinks.map((l) => (
      <a href={l.href} class="ulink">{l.label}</a>
    ))}
  </nav>
</header>

<script>
  const nav = document.getElementById('au-nav');
  const toggle = nav?.querySelector('.au-nav__toggle');
  const links = nav?.querySelectorAll('.au-nav__links a');

  // scroll background
  const onScroll = () => {
    if (!nav) return;
    nav.classList.toggle('scrolled', window.scrollY > 80);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // mobile menu
  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
  links?.forEach((l) =>
    l.addEventListener('click', () => {
      nav?.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
    })
  );
</script>
