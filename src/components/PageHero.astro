---
/* PageHero — zdieľaný hero podstránok vertikál: TEXT VĽAVO, zatmavená FOTO VPRAVO.
   Na mobile stack (text, potom foto). Texty (h1/sub/lead) idú cez <slot> z rodiča —
   typografiu .au-subhero-* rieši global.css (slot obsah nededí scoped štýly). */
interface Props {
  eyebrow: string;
  photo: string;
  alt: string;
}
const { eyebrow, photo, alt } = Astro.props;
---
<section class="au-subhero">
  <div class="au-subhero-text">
    <div class="d1-eyebrow"><span class="d1-eyebrow-title">{eyebrow}</span></div>
    <slot />
  </div>
  <figure class="au-subhero-media">
    <img src={photo} alt={alt} loading="eager" fetchpriority="high" decoding="async" />
  </figure>
</section>
