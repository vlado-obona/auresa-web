---
/* PageHero — zdieľaný hero podstránok vertikál: FOTO ako POZADIE celej sekcie
   + bone „závoj" s prechodom priehľadnosti (desktop zľava→doprava, mobil zhora→nadol).
   Text (vľavo) je nad závojom. Typografiu .au-subhero-* rieši global.css (slot z rodiča). */
interface Props {
  eyebrow: string;
  photo: string;
  alt: string;
  ctaText?: string;
  ctaHref?: string;
}
const { eyebrow, photo, alt, ctaText, ctaHref } = Astro.props;
---
<section class="au-subhero">
  <img class="au-subhero-bg" src={photo} alt={alt} loading="eager" fetchpriority="high" decoding="async" />
  <div class="au-subhero-veil" aria-hidden="true"></div>
  <div class="au-subhero-text">
    <div class="d1-eyebrow"><span class="d1-eyebrow-title">{eyebrow}</span></div>
    <slot />
    {ctaText && ctaHref && (
      <a href={ctaHref} class="au-cta au-subhero-cta">{ctaText} <span class="arr">→</span></a>
    )}
  </div>
</section>
