---
/* CookieBanner — vlastný consent (žiadna externá knižnica).
   - Súhlasím / Odmietnuť rovnocenne (žiadne predzaškrtnutie).
   - Voľba v localStorage 'au-consent' = {state:'granted'|'denied', ts}.
   - GA4 sa načíta LEN po 'granted' a LEN na produkčnom hostname (auresa.sk);
     na test.auresa.sk je mechanizmus prítomný, ale dormantný.
   - GTM (prázdny kontajner) sa načíta rovnako consent-gated: LEN po 'granted'
     a LEN na čistom prod hostname auresa.sk (www/test/staging/localhost dormantné).
   - Reset cez [data-cookie-reset] (footer + /cookies/) — odvolanie = rovnako ľahké. */
import { GA4_ID, GTM_ID } from '../data/site';
---
<div class="au-cookie" data-cookie hidden tabindex="-1" role="dialog" aria-label="Súhlas s cookies" aria-describedby="au-cookie-desc">
  <p id="au-cookie-desc">
    Používame nevyhnutné cookies pre chod webu a — s vaším súhlasom — anonymnú štatistiku
    návštevnosti (Google Analytics). <a class="au-cookie-more" href="/cookies/">Viac informácií →</a>
  </p>
  <div class="au-cookie-actions">
    <button type="button" class="au-cookie-btn au-cookie-accept" data-cookie-accept>Súhlasím</button>
    <button type="button" class="au-cookie-btn au-cookie-reject" data-cookie-reject>Odmietnuť</button>
  </div>
</div>

<script define:vars={{ GA4_ID, GTM_ID }}>
  (function () {
    const KEY = 'au-consent';
    const PROD_HOSTS = ['auresa.sk', 'www.auresa.sk'];
    const isProd = PROD_HOSTS.indexOf(location.hostname) !== -1;
    const MAX_AGE_MS = 365 * 24 * 3600 * 1000;     // súhlas obnoviť po ~12 mes.
    const DISABLE_FLAG = 'ga-disable-' + GA4_ID;   // oficiálny GA opt-out flag
    const banner = document.querySelector('[data-cookie]');

    function getConsent() {
      try { return JSON.parse(localStorage.getItem(KEY) || 'null'); } catch { return null; }
    }
    function setConsent(state) {
      try { localStorage.setItem(KEY, JSON.stringify({ state: state, ts: Date.now() })); } catch {}
    }
    function clearConsent() { try { localStorage.removeItem(KEY); } catch {} }
    function showBanner() {
      if (!banner) return;
      banner.hidden = false; banner.classList.add('show');
      try { banner.focus(); } catch {}             // presun focusu do dialógu (a11y)
    }
    function hideBanner() { if (banner) { banner.classList.remove('show'); banner.hidden = true; } }

    function loadGA4() {
      if (!isProd) return;                 // dormantné mimo produkcie (test.auresa.sk)
      window[DISABLE_FLAG] = false;        // re-enable po opätovnom súhlase
      if (window.__au_ga4) return;
      window.__au_ga4 = true;
      const s = document.createElement('script');
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA4_ID;
      document.head.appendChild(s);
      window.dataLayer = window.dataLayer || [];
      window.gtag = function () { window.dataLayer.push(arguments); };
      window.gtag('js', new Date());
      window.gtag('config', GA4_ID);
    }
    // GTM — prázdny kontajner, consent-gated, LEN na čistom prod hostname auresa.sk.
    // (www/test/staging/localhost = dormantné; www aj tak 301 → auresa.sk.)
    function loadGTM() {
      if (location.hostname !== 'auresa.sk') return;   // dormantné mimo čistého prod
      if (window.__au_gtm) return;
      window.__au_gtm = true;
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ 'gtm.start': Date.now(), event: 'gtm.js' });
      const s = document.createElement('script');
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtm.js?id=' + GTM_ID;
      document.head.appendChild(s);
    }
    function disableGA() {
      window[DISABLE_FLAG] = true;         // okamžite zastaví bežiaci GA do reloadu
      window.__au_ga4 = false;
      window.__au_gtm = false;             // GTM sa pri ďalšom načítaní nenačíta (prázdny kontajner)
    }
    function deleteGACookies() {
      const base = location.hostname.replace(/^www\./, '');
      const names = ['_ga', '_ga_' + GA4_ID.replace(/^G-/, '')];
      names.forEach(function (n) {
        document.cookie = n + '=; Max-Age=0; path=/';
        document.cookie = n + '=; Max-Age=0; path=/; domain=' + location.hostname;
        document.cookie = n + '=; Max-Age=0; path=/; domain=.' + base;
      });
    }

    // init — validácia tvaru + expirácia
    const c = getConsent();
    const valid = !!c && (c.state === 'granted' || c.state === 'denied');
    const expired = valid && (!c.ts || Date.now() - c.ts > MAX_AGE_MS);
    if (!valid || expired) { clearConsent(); showBanner(); }
    else if (c.state === 'granted') { loadGA4(); loadGTM(); }

    // delegované akcie (banner + reset odkazy v footeri/cookies)
    document.addEventListener('click', function (e) {
      const el = e.target instanceof Element ? e.target : null;
      if (!el) return;
      if (el.closest('[data-cookie-accept]')) { setConsent('granted'); hideBanner(); loadGA4(); loadGTM(); }
      else if (el.closest('[data-cookie-reject]')) { setConsent('denied'); hideBanner(); disableGA(); deleteGACookies(); }
      else if (el.closest('[data-cookie-reset]')) {
        e.preventDefault();
        clearConsent(); disableGA(); deleteGACookies(); showBanner();
      }
    });
  })();
</script>
