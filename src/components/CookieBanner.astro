---
/* CookieBanner — minimalistický, vlastný (žiadna externá knižnica).
   Zobrazí sa len ak localStorage 'au-consent' nie je nastavené. */
---
<div class="au-cookie" data-cookie hidden>
  <p>Používame funkčné cookies pre správne fungovanie webu.</p>
  <div class="au-cookie-actions">
    <button type="button" class="au-cookie-accept" data-cookie-accept>Súhlasím</button>
    <a class="au-cookie-more" href="/cookies/">Viac informácií →</a>
  </div>
</div>

<script>
  const banner = document.querySelector('[data-cookie]');
  const accept = document.querySelector('[data-cookie-accept]');
  if (banner) {
    try {
      if (!localStorage.getItem('au-consent')) {
        banner.hidden = false;
        banner.classList.add('show');
      }
    } catch { /* localStorage nedostupné — banner nezobraziť */ }
    accept?.addEventListener('click', () => {
      try { localStorage.setItem('au-consent', '1'); } catch {}
      banner.classList.remove('show');
      banner.hidden = true;
    });
  }
</script>
