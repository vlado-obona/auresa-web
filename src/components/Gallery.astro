---
/* Galéria realizácie — responzívna mriežka + lightbox (vanilla, bez knižnice).
   Lazy-loading náhľadov. */
interface Props { images: string[]; alt: string; }
const { images, alt } = Astro.props;
---
<div class="au-gallery" data-gallery>
  {images.map((src, i) => (
    <button type="button" class="au-gallery-item" data-index={i} aria-label={`Zobraziť fotku ${i + 1} z ${images.length}`}>
      <img src={src} alt={`${alt} — fotka ${i + 1}`} loading="lazy" decoding="async" />
    </button>
  ))}
</div>

<div class="au-lightbox" data-lightbox hidden role="dialog" aria-modal="true" aria-label="Galéria">
  <button class="au-lb-close" data-lb-close aria-label="Zavrieť">×</button>
  <button class="au-lb-nav au-lb-prev" data-lb-prev aria-label="Predošlá">‹</button>
  <img class="au-lb-img" data-lb-img src="" alt="" />
  <button class="au-lb-nav au-lb-next" data-lb-next aria-label="Ďalšia">›</button>
  <div class="au-lb-counter" data-lb-counter></div>
</div>

<script is:inline define:vars={{ images, alt }}>
  (function () {
    const grid = document.querySelector('[data-gallery]');
    const lb = document.querySelector('[data-lightbox]');
    if (!grid || !lb) return;
    const img = lb.querySelector('[data-lb-img]');
    const counter = lb.querySelector('[data-lb-counter]');
    let idx = 0;
    let lastFocus = null;

    function show(i) {
      idx = (i + images.length) % images.length;
      img.src = images[idx];
      img.alt = alt + ' — fotka ' + (idx + 1);
      counter.textContent = (idx + 1) + ' / ' + images.length;
    }
    function open(i) {
      lastFocus = document.activeElement;
      show(i);
      lb.hidden = false;
      requestAnimationFrame(() => lb.classList.add('open'));
      document.body.style.overflow = 'hidden';
    }
    function close() {
      lb.classList.remove('open');
      document.body.style.overflow = '';
      setTimeout(() => { lb.hidden = true; }, 300);
      if (lastFocus && lastFocus.focus) lastFocus.focus();
    }

    grid.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-index]');
      if (btn) open(parseInt(btn.getAttribute('data-index'), 10));
    });
    lb.querySelector('[data-lb-close]').addEventListener('click', close);
    lb.querySelector('[data-lb-prev]').addEventListener('click', () => show(idx - 1));
    lb.querySelector('[data-lb-next]').addEventListener('click', () => show(idx + 1));
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
    document.addEventListener('keydown', (e) => {
      if (lb.hidden) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(idx - 1);
      else if (e.key === 'ArrowRight') show(idx + 1);
    });
  })();
</script>

<style>
  .au-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }
  .au-gallery-item {
    display: block; padding: 0; border: 0; cursor: pointer;
    aspect-ratio: 4 / 3; overflow: hidden; background: var(--au-bg-2);
  }
  .au-gallery-item img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s ease, opacity 0.3s ease;
  }
  .au-gallery-item:hover img, .au-gallery-item:focus-visible img { transform: scale(1.05); }

  .au-lightbox {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(46, 42, 36, 0.94);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.3s ease;
  }
  /* KRITICKÉ: zatvorený lightbox musí byť display:none, inak neviditeľný overlay
     (opacity:0, z-index:200, inset:0) požiera VŠETKY kliky na stránke. Autorské
     display:flex prebíja UA [hidden]{display:none}, preto to treba explicitne. */
  .au-lightbox[hidden] { display: none; }
  .au-lightbox.open { opacity: 1; }
  .au-lb-img {
    max-width: 92vw; max-height: 88vh; object-fit: contain;
    box-shadow: 0 12px 60px rgba(0,0,0,0.5);
  }
  .au-lb-close, .au-lb-nav {
    position: absolute; background: none; border: 0; color: var(--bone);
    cursor: pointer; line-height: 1; opacity: 0.8; transition: opacity 0.2s;
  }
  .au-lb-close:hover, .au-lb-nav:hover { opacity: 1; }
  .au-lb-close { top: 18px; right: 24px; font-size: 40px; }
  .au-lb-nav { top: 50%; transform: translateY(-50%); font-size: 56px; padding: 0 18px; }
  .au-lb-prev { left: 8px; }
  .au-lb-next { right: 8px; }
  .au-lb-counter {
    position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
    color: var(--bone); font-family: var(--sans); font-size: 12px; letter-spacing: 0.2em;
    opacity: 0.85;
  }
  @media (max-width: 900px) { .au-gallery { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) {
    .au-gallery { grid-template-columns: 1fr; }
    .au-lb-nav { font-size: 40px; padding: 0 10px; }
  }
</style>
