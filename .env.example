# Skopíruj na `.env` (gitignored) a doplň reálne hodnoty na serveri.
# NIKDY necommituj `.env` s reálnymi tajomstvami.

# GitHub OAuth pre Decap CMS (public/api/auth.php)
GITHUB_CLIENT_ID=__DOPLNIT__
GITHUB_CLIENT_SECRET=__DOPLNIT__

# SMTP pre kontaktný formulár (public/api/kontakt.php)
SMTP_HOST=smtp.websupport.sk
SMTP_PORT=465
SMTP_USER=info@auresa.sk
SMTP_PASS=__DOPLNIT__
SMTP_FROM=info@auresa.sk
SMTP_FROM_NAME=Auresa Design Studio
